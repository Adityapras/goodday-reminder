# ============================================================
# GoodDay Daily Reminder — konfigurasi
# Copy file ini jadi `.env` lalu isi nilainya:
#   cp .env.example .env
# JANGAN commit .env ke git (berisi kredensial).
# ============================================================

# Token admin GoodDay (Settings > Integrations > API)
GOODDAY_API_TOKEN=

# Token bot Telegram dari @BotFather
TELEGRAM_BOT_TOKEN=

# Opsional: lokasi database SQLite.
# Default: reminders.db di folder yang sama dengan script.
# DB_PATH=/var/lib/goodday-reminder/reminders.db

# ------------------------------------------------------------
# Digest tim ke group/topic (perintah `digest`) — opsional
# ------------------------------------------------------------
# ⏸ Fitur digest lagi DIMATIKAN default (keputusan 2026-07-07).
# Set 1 buat menyalakan lagi: /digest di bot, cron digest, & menu perintah.
DIGEST_ENABLED=0

# Chat id group tujuan (angka, group besar biasanya diawali -100).
# Bot harus jadi anggota group itu.
DIGEST_CHAT_ID=

# Id topic (message_thread_id) kalau group pakai Topics.
# Cara dapat: buka topic di Telegram Web -> URL-nya t.me/c/<xxx>/<TOPIC_ID>.
# Kosongkan kalau mau kirim ke General / group biasa.
DIGEST_TOPIC_ID=

# User GoodDay yang dilaporkan, pisah koma (lihat id-nya via `gd-users`).
# Kosongkan = semua penerima yang udah ke-link.
# Contoh: DIGEST_GD_USERS=yt5Qk4,p1XK1k,jnQ5GE
DIGEST_GD_USERS=

# Opsional: token bot LAIN yang udah jadi anggota group — digest dikirim
# lewat bot itu. Tombol "Detail" otomatis jadi deep-link ke DM bot reminder
# (karena tombol callback cuma bisa dilayani bot pengirim pesan).
# Kosongkan = digest dikirim bot reminder sendiri (TELEGRAM_BOT_TOKEN).
DIGEST_BOT_TOKEN=

# ------------------------------------------------------------
# Opsifin Bot interaktif (mode `bot`)
# ------------------------------------------------------------
# Chat_id Telegram para admin (pisah koma). Pendaftaran baru dikirim ke DM
# mereka dengan tombol Approve/Tolak. ⚠️ Kosong = pendaftaran AUTO-APPROVE.
ADMIN_CHAT_IDS=

# Syarat label 🟢 SIAP DIKERJAKAN (default sesuai workspace Opsifin):
# custom field dropdown "Product Stream" + nilai yang wajib, dan
# custom field checkbox "Delivery Task" yang wajib dicentang.
READY_STREAM_FIELD=gLu7pt
READY_STREAM_VALUE=8
READY_DELIVERY_FIELD=ZJVsCT

# Sumber story point buat ready-check: "estimate" atau "storyPoints".
# ⚠️ Terverifikasi 2026-07-07: API GoodDay TIDAK pernah mengembalikan
# storyPoints (bahkan setelah di-set via API) — pakai "estimate".
READY_STORYPOINT_SOURCE=estimate

# Custom field yang boleh diubah user dari Telegram (whitelist id, pisah koma).
EDIT_CUSTOM_FIELDS=gLu7pt,ZJVsCT

# ------------------------------------------------------------
# AI layer (opsional; scaffold — provider-agnostic)
# ------------------------------------------------------------
# Provider: anthropic | openai | gemini | ollama | custom
AI_PROVIDER=
# API key generik (ANTHROPIC_API_KEY lama juga masih dibaca sbg fallback)
AI_API_KEY=
# Contoh model: anthropic=claude-opus-4-8 · openai=gpt-* · ollama=llama3
AI_MODEL=
# Endpoint custom/self-hosted kompatibel OpenAI (mis. http://localhost:11434/v1)
AI_BASE_URL=
